# ─── LiveKit Cloud ────────────────────────────────────────────────────────────
# Get these from https://cloud.livekit.io → your project → Settings → API Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Deepgram (STT) ───────────────────────────────────────────────────────────
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Gemini (LLM – fast, low-latency) ───────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cartesia (TTS) ───────────────────────────────────────────────────────────
# Get from https://play.cartesia.ai → API Keys
CARTESIA_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Voice ID – use "a0e99841-438c-4a64-b679-ae501e7d6091" (Barbershop Man) or pick from dashboard
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# ─── Server config ────────────────────────────────────────────────────────────
# Room name the bot will join (must match frontend)
ROOM_NAME=plumbing-support
# Port for the FastAPI token/bot server
SERVER_PORT=8000
